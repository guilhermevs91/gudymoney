# =============================================================================
# Gudy Money API — Environment Variables Example
# Copy this file to .env and fill in the values before running the API.
# NEVER commit .env or .env.prod to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://gudy:password@localhost:5432/gudy_money

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
TZ=America/Sao_Paulo

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# -----------------------------------------------------------------------------
# Asaas (payment gateway)
# -----------------------------------------------------------------------------
ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

# -----------------------------------------------------------------------------
# SuperAdmin
# -----------------------------------------------------------------------------
SUPERADMIN_JWT_SECRET=your-superadmin-secret-min-32-chars
