{
  "name": "@gudy/api",
  "version": "1.0.5",
  "private": true,
  "scripts": {
    "dev": "prisma generate && ts-node-dev --respawn --transpile-only --exit-child src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "dependencies": {
    "@gudy/shared": "workspace:*",
    "@prisma/client": "^5.14",
    "bcrypt": "^5",
    "google-auth-library": "^9",
    "multer": "^1.4",
    "cors": "^2.8",
    "dotenv": "^16",
    "express": "^4.19",
    "express-rate-limit": "^7",
    "helmet": "^7",
    "jsonwebtoken": "^9",
    "node-cron": "^3",
    "uuid": "^10",
    "zod": "^3.23"
  },
  "devDependencies": {
    "@types/bcrypt": "*",
    "@types/cors": "*",
    "@types/express": "*",
    "@types/jsonwebtoken": "*",
    "@types/node": "*",
    "@types/node-cron": "^3",
    "@types/multer": "*",
    "@types/jest": "^29",
    "@types/supertest": "^6",
    "jest": "^29",
    "prisma": "^5.14",
    "supertest": "^7",
    "ts-jest": "^29",
    "ts-node-dev": "^2",
    "typescript": "*"
  }
}
