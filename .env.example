# =============================================================================
# Gudy Money — variáveis de ambiente de exemplo
# Copie para .env e preencha os valores antes de iniciar.
# NUNCA commite .env ou .env.prod no repositório.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://gudy:password@localhost:5432/gudy_money
POSTGRES_PASSWORD=password

# -----------------------------------------------------------------------------
# JWT — gere com: openssl rand -hex 64
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret_min_32_chars
SUPERADMIN_JWT_SECRET=change_me_superadmin_secret_min_32_chars

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
TZ=America/Sao_Paulo

# -----------------------------------------------------------------------------
# Google OAuth
# Google Cloud Console → Credenciais → ID do cliente OAuth 2.0 (Aplicativo da web)
# Origens JS autorizadas: http://localhost:3000
# URIs de redirecionamento: gudy-money:// (mobile)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET não é usado no fluxo SPA (verify id_token)

# -----------------------------------------------------------------------------
# Asaas (gateway de pagamento)
# -----------------------------------------------------------------------------
ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=

# -----------------------------------------------------------------------------
# Webhooks de saída (HMAC-SHA256)
# -----------------------------------------------------------------------------
WEBHOOK_SIGNING_SECRET=change_me_webhook_signing_secret

# -----------------------------------------------------------------------------
# Web (Next.js — variáveis com NEXT_PUBLIC_ ficam expostas ao browser)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# -----------------------------------------------------------------------------
# Mobile (Expo — variáveis com EXPO_PUBLIC_ ficam expostas ao app)
# -----------------------------------------------------------------------------
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# -----------------------------------------------------------------------------
# Redis (v2 — BullMQ, não necessário na v1)
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379
