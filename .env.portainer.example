# =============================================================================
# Gudy Money — Variáveis de ambiente para deploy no Portainer
# Copie este arquivo para .env.portainer e preencha os valores
# NUNCA commite o arquivo preenchido no git
# =============================================================================

# -----------------------------------------------------------------------------
# Postgres — use as credenciais do container postgres-app existente
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres-app        # nome do container ou IP interno
POSTGRES_PORT=5432
POSTGRES_DB=gudy_money            # crie este banco no postgres-app
POSTGRES_USER=gudy                # crie este usuário no postgres-app
POSTGRES_PASSWORD=troque_por_senha_forte

# -----------------------------------------------------------------------------
# Rede externa do servidor onde está o postgres-app
# Descubra com: docker network ls
# -----------------------------------------------------------------------------
SERVER_NETWORK=server_default

# -----------------------------------------------------------------------------
# JWT — gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_SECRET=gere_um_segredo_aleatorio_aqui
JWT_REFRESH_SECRET=gere_outro_segredo_aleatorio_aqui
SUPERADMIN_JWT_SECRET=gere_mais_um_segredo_aqui

# -----------------------------------------------------------------------------
# URLs públicas
# URL que o BROWSER usa para chamar a API (domínio ou IP:porta do servidor)
# -----------------------------------------------------------------------------
PUBLIC_API_URL=http://SEU_IP_OU_DOMINIO/api

# Portas expostas no servidor (para o nginx externo apontar)
API_PORT=3001
WEB_PORT=3000

# -----------------------------------------------------------------------------
# Google OAuth (opcional)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Asaas (opcional)
# -----------------------------------------------------------------------------
ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
